# Dev: `npm run dev` → http://localhost:3000 (Express + Vite; /api/* aqui).
# Se usar `npm run dev:vite` na 5173, deixe `npm run dev` rodando na 3000 (proxy /api).

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# Supabase (projeto Radar de Cria). Rode supabase/places_cache.sql no SQL Editor.
# Ex.: https://irzzfetazbrzalwswais.supabase.co
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Servidor Node (cache /api/places): use a mesma URL; prefira service_role no backend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# MAPBOX_ACCESS_TOKEN: Required for Mapbox maps.
MAPBOX_ACCESS_TOKEN=

# GOOGLE_PLACES_API_KEY: Required for Google Places API.
GOOGLE_PLACES_API_KEY=

# GEOAPIFY_API_KEY: Required for Geoapify API fallback (Optional).
GEOAPIFY_API_KEY=

# --- Vercel (Environment Variables no painel) ---
# Front (build): VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, GEMINI_API_KEY (se usar).
# Serverless /api/* (runtime): MAPBOX_ACCESS_TOKEN, GOOGLE_PLACES_API_KEY, GEOAPIFY_API_KEY,
# SUPABASE_URL e SUPABASE_ANON_KEY (ou SUPABASE_SERVICE_ROLE_KEY no servidor apenas).
# A chave do Google Places não vai mais para o bundle do Vite (só no backend).
